# Copy this file to .env for local development.
# On Railway, set these as environment variables in the service settings.

# Required: a long random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Optional: pre-fill default instance names in the login form
# HAMMER_DEFAULT_SRC_INSTANCE=gilbane
# HAMMER_DEFAULT_DST_INSTANCE=anotherclient
